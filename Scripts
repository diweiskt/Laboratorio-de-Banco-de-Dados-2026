-- Faça um procedure para armazenar em um CURSOR o id, status da consulta e 
-- o nome e a descrição do procedimento que a consulta gerou. Depois recupere do CURSOR 
-- e apresente o id e a descrição dos procedimentos, apenas das consultas realizadas.

   CREATE or replace PROCEDURE p_c1 IS
     CURSOR c1 IS
               SELECT    c.id_consulta,c.status,p.nome_procd,p.descricao
               FROM      consulta c inner join procedimento p ON
                         c.id_consulta = p.id_consulta;
                         
     v_reg c1%ROWTYPE;  -- variável do mesmo tipo que o cursor que vai apontar para o conteúdo                  
     BEGIN                    
       OPEN c1;
       LOOP
         FETCH c1 INTO v_reg; 
         EXIT WHEN c1%NOTFOUND;
          IF (v_reg.status = 'realizada')THEN
           DBMS_OUTPUT.PUT_LINE(v_reg.id_consulta || ' => ' || v_reg.descricao || ':'|| v_reg.status);
          END IF; 
       END LOOP;
       CLOSE c1;
     END;

