-- 1- Faça um procedure PL/SQL para atualizar o status de uma consulta.
   CREATE or replace PROCEDURE p_q1 (vId IN CONSULTA.id_consulta%TYPE, 
                                     vStatus IN CONSULTA.status%TYPE) IS                               
    varStatusBanco CONSULTA.status%TYPE;                                 
   BEGIN
      -- verifica Status que está no Banco
      SELECT  status    INTO varStatusBanco
      FROM    Consulta 
      WHERE   id_consulta = vId;
      -- testa se o Status é diferente da opção de alteração
      IF (varStatusBanco <> 'realizada') and (varStatusBanco <> vStatus) THEN
        UPDATE  Consulta  
        SET     status = vStatus
        WHERE   id_consulta = vId;
      ELSE
        DBMS_OUTPUT.put_LINE('Opa, o status é o mesmo, tem erro aí!!!');
      END IF;  
   END p_q1;
   
   EXEC p_q1(1,'agendada');   -- Select * From consulta
   

