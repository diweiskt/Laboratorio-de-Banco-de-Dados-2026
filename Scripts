 -- - soma dos pagamentos feitos
 -- - por período (data inicial e final)
 -- * Utiliza JOIN entre as tabelas CONSULTA, PAGAMENTO e MEDICO
 
   CREATE or replace FUNCTION f_fatura(varM CONSULTA.id_medico%TYPE,
                                       varPi CONSULTA.data%TYPE, 
                                       varPf CONSULTA.data%TYPE)
   RETURN NUMBER IS
      varFaturamento  NUMBER;
   BEGIN    
        SELECT SUM(p.valor_pagto)  INTO varFaturamento
        FROM Consulta c inner join Pagamento p ON c.id_consulta = p.id_consulta
             inner join Medico m ON c.id_medico = m.id_medico
        WHERE c.id_medico = varM AND c.status = 'realizada'
              AND c.data BETWEEN varPi AND varPf;
  
       RETURN varFaturamento;  
   END f_fatura;
 
