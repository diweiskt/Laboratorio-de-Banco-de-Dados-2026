  CREATE OR REPLACE PROCEDURE p_q3 (
    vId_consulta IN CONSULTA.id_consulta%TYPE,
    vData        IN CONSULTA.data%TYPE,
    vHora        IN CONSULTA.hora%TYPE,
    vValor       IN CONSULTA.valor%TYPE,
    vObs         IN CONSULTA.obs%TYPE,
    vId_paciente IN CONSULTA.id_paciente%TYPE,
    vId_medico   IN CONSULTA.id_medico%TYPE
) IS
  vP   INT;     vM   INT; vH   INT;
BEGIN
     SELECT count(*) INTO vP  FROM   paciente  WHERE id_paciente = vId_paciente;
     IF (vp = 0) THEN
        raise_application_error(-20001,'Esse Paciente não existe!');
     END IF;
     SELECT count(*) INTO vM  FROM medico  WHERE id_medico = vId_medico;
     IF (vp = 0) THEN
